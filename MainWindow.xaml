<Window x:Class="Project_PRN212.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Project_PRN212.Views"
        Title="Hệ thống Dream Kitchen VN" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MaxWidth="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <views:Sidebar x:Name="AppSidebar" Grid.Column="0" Visibility="Collapsed" />

        <!-- Main Content Area -->
        <Grid x:Name="MainContentGrid" Grid.Column="1" Background="#ECF0F1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <views:Header x:Name="AppHeader" Grid.Row="0" Visibility="Collapsed" />

            <!-- Navigation Frame -->
            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</Window>