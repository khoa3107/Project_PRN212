<Page x:Class="Project_PRN212.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Đăng Nhập" Background="#F4F6F9">

    <Grid>
        <Border Width="400" Height="450" Background="White" CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.05" Direction="270" ShadowDepth="4"/>
            </Border.Effect>
            
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ĐĂNG NHẬP" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Hệ Thống Quản Lý Chuỗi Bếp" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                
                <TextBlock Text="Tên đăng nhập" Foreground="#34495E" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Height="42" Padding="12,10" FontSize="15" BorderBrush="#CBD5E1" BorderThickness="1" Background="#F8FAFC">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <TextBlock Text="Mật khẩu" Foreground="#34495E" FontWeight="SemiBold" Margin="0,20,0,5"/>
                <PasswordBox x:Name="pwdPassword" Height="42" Padding="12,10" FontSize="15" BorderBrush="#CBD5E1" BorderThickness="1" Background="#F8FAFC">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                
                <TextBlock x:Name="txtError" Foreground="#E74C3C" FontSize="13" Margin="0,15,0,0" HorizontalAlignment="Center" Height="20"/>
                
                <Button Content="Đăng Nhập" Height="45" Margin="0,20,0,0" Background="#3498DB" Foreground="White"
                        FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>