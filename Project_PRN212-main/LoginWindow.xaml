<Window x:Class="Project_PRN212.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập - Dream Kitchen VN" Height="300" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ĐĂNG NHẬP" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Tài khoản:" Margin="0,5,0,2"/>
        <TextBox Grid.Row="2" x:Name="txtUsername" Margin="0,0,0,10" Height="25"/>
        
        <TextBlock Grid.Row="3" Text="Mật khẩu:" Margin="0,5,0,2"/>
        <PasswordBox Grid.Row="4" x:Name="pwdPassword" Margin="0,0,0,15" Height="25"/>
        
        <Button Grid.Row="5" Content="Đăng nhập" Height="30" Background="#007ACC" Foreground="White" FontWeight="Bold" Click="BtnLogin_Click"/>
        
        <TextBlock Grid.Row="6" x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" />
    </Grid>

</Window>