<UserControl x:Class="Project_PRN212.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Background="#2C3E50" Foreground="White">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#34495E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,30,0,20">
            <TextBlock Text="DREAM KITCHEN" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Foreground="#ECF0F1" Margin="0,0,0,5"/>
            <TextBlock Text="Quản lý Chuỗi" FontWeight="Normal" FontSize="12" HorizontalAlignment="Center" Foreground="#BDC3C7"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1">
            <Button x:Name="btnDashboard" Content="📊 Dashboard" Click="NavDashboard_Click" Visibility="Collapsed"/>
            <Button x:Name="btnUser" Content="👥 Quản lý User" Click="NavUser_Click" Visibility="Collapsed"/>
            <Button x:Name="btnInventory" Content="📦 Kho nguyên liệu" Click="NavInventory_Click" Visibility="Collapsed"/>
            <Button x:Name="btnProduction" Content="🥘 Kế hoạch sản xuất" Click="NavProduction_Click" Visibility="Collapsed"/>
            <Button x:Name="btnDelivery" Content="🚚 Giao &amp; Nhận hàng" Click="NavDelivery_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>