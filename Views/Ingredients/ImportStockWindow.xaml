<Window x:Class="Project_PRN212.Views.Ingredients.ImportStockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập Kho Nguyên Liệu"
        Height="260" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📦 Nhập Kho" FontSize="16" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" x:Name="txtIngredientInfo" Foreground="#495057" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="2" Text="Số lượng nhập thêm *" Margin="0,0,0,3"/>
        <TextBox   Grid.Row="3" x:Name="txtQuantity" Height="28" Padding="5,3" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Text="Giá nhập mới (để trống = giữ nguyên)" Margin="0,0,0,3"/>
        <TextBox   Grid.Row="5" x:Name="txtNewPrice" Height="28" Padding="5,3" Margin="0,0,0,0" VerticalAlignment="Top"/>

        <TextBlock x:Name="txtError" Grid.Row="5" Foreground="Red" VerticalAlignment="Bottom" Margin="0,0,0,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Hủy" Width="70" Height="28" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Nhập kho" Width="90" Height="28" Background="#fd7e14" Foreground="White"
                    FontWeight="Bold" Click="BtnImport_Click"/>
        </StackPanel>
    </Grid>
</Window>
