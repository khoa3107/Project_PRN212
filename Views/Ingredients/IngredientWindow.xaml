<Window x:Class="Project_PRN212.Views.Ingredients.IngredientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Nguyên Liệu - Kho Bếp Trung Tâm"
        Height="620" Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Text="🧂 Quản lý Nguyên Liệu &amp; Kho"
                   FontSize="20" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,12"/>

        <!-- Thanh tìm kiếm + lọc -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="txtSearch" Height="28" Margin="0,0,8,0"
                     VerticalContentAlignment="Center" Padding="5,0"
                     Text="Tìm kiếm tên nguyên liệu..."
                     Foreground="Gray"
                     GotFocus="TxtSearch_GotFocus"
                     LostFocus="TxtSearch_LostFocus"
                     TextChanged="TxtSearch_TextChanged"/>

            <ComboBox Grid.Column="1" x:Name="cboStatus" Height="28" Margin="0,0,8,0"
                      SelectedIndex="0" SelectionChanged="CboStatus_SelectionChanged">
                <ComboBoxItem Content="Tất cả trạng thái"/>
                <ComboBoxItem Content="Available"/>
                <ComboBoxItem Content="Unavailable"/>
            </ComboBox>

            <Button Grid.Column="2" Content="🔄 Làm mới" Height="28" Margin="0,0,8,0"
                    Click="BtnRefresh_Click" Background="#6c757d" Foreground="White"/>
            <Button Grid.Column="3" Content="➕ Thêm" Height="28"
                    Click="BtnAdd_Click" Background="#28a745" Foreground="White" FontWeight="Bold"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="dgIngredients"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#f8f9fa"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#dee2e6"
                  RowHeight="32"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"            Binding="{Binding IngredientId}" Width="50"/>
                <DataGridTextColumn Header="Tên Nguyên Liệu" Binding="{Binding IngredientName}" Width="200"/>
                <DataGridTextColumn Header="Đơn vị"        Binding="{Binding Unit}"          Width="80"/>
                <DataGridTextColumn Header="Tồn kho"       Binding="{Binding QuantityInStock, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Giá nhập (VNĐ)" Binding="{Binding ImportPrice, StringFormat=N0}" Width="130"/>
                <DataGridTextColumn Header="Cập nhật lần cuối" Binding="{Binding LastUpdated, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Trạng thái"    Binding="{Binding Status}"        Width="100"/>

                <DataGridTemplateColumn Header="Thao tác" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️ Sửa" Width="60" Height="24" Margin="2,0"
                                        Background="#007bff" Foreground="White"
                                        Tag="{Binding IngredientId}"
                                        Click="BtnEdit_Click"/>
                                <Button Content="🗑️ Xóa" Width="60" Height="24" Margin="2,0"
                                        Background="#dc3545" Foreground="White"
                                        Tag="{Binding IngredientId}"
                                        Click="BtnDelete_Click"/>
                                <Button Content="📦 Nhập kho" Width="85" Height="24" Margin="2,0"
                                        Background="#fd7e14" Foreground="White"
                                        Tag="{Binding IngredientId}"
                                        Click="BtnImport_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#f1f3f5" BorderBrush="#dee2e6" BorderThickness="0,1,0,0" Padding="8,5" Margin="0,8,0,0">
            <Grid>
                <TextBlock x:Name="txtStatus" Text="Sẵn sàng" Foreground="#495057" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtCount" HorizontalAlignment="Right" Foreground="#6c757d" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
