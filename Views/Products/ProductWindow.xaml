<Window x:Class="Project_PRN212.Views.Products.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Thành Phẩm (Product)" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Danh sách Thành Phẩm (Product)" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Món" Binding="{Binding DishId}" Width="80"/>
                <DataGridTextColumn Header="Tên Món" Binding="{Binding DishName}" Width="*"/>
                <DataGridTextColumn Header="Số Lượng" Binding="{Binding ProducedQuantity}" Width="100"/>
                <DataGridTextColumn Header="Đơn Vị" Binding="{Binding Unit}" Width="80"/>
                <DataGridTextColumn Header="Ngày SX" Binding="{Binding ProductionDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="HSD" Binding="{Binding ExpiryDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>