<Window x:Class="Project_PRN212.Views.Products.ProductFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh sửa Thành Phẩm" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chỉnh sửa Thành Phẩm" FontSize="16" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Tên món *" Margin="0,0,0,3"/>
        <TextBox   Grid.Row="2" x:Name="txtDishName" Height="28" Padding="5,3" Margin="0,0,0,10"/>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Số lượng *" Margin="0,0,0,3"/>
                <TextBox x:Name="txtQty" Height="28" Padding="5,3"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Đơn vị *" Margin="0,0,0,3"/>
                <TextBox x:Name="txtUnit" Height="28" Padding="5,3"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="HSD (yyyy-MM-dd)" Margin="0,0,0,3"/>
                <TextBox x:Name="txtExpiry" Height="28" Padding="5,3"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Trạng thái *" Margin="0,0,0,3"/>
                <ComboBox x:Name="cmbStatus" Height="28" Padding="5,3">
                    <ComboBoxItem Content="Available"/>
                    <ComboBoxItem Content="Expired"/>
                    <ComboBoxItem Content="Out of Stock"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="5" x:Name="txtError" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Hủy bỏ" Width="80" Height="30" Margin="0,0,10,0" Background="#f8f9fa" Click="BtnCancel_Click"/>
            <Button Content="Lưu" Width="80" Height="30" Background="#28a745" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>