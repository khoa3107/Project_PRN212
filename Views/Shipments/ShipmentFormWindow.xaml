<Window x:Class="Project_PRN212.Views.Shipments.ShipmentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo Phiếu Xuất Mới" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Thông Tin Phiếu Xuất" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Cửa hàng:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1" x:Name="cboStore" DisplayMemberPath="StoreName" SelectedValuePath="StoreId" Height="28" Margin="0,0,15,0"/>

            <TextBlock Grid.Column="2" Text="Ghi chú:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="3" x:Name="txtNote" Height="28"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Món ăn:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cboDish" DisplayMemberPath="DishName" SelectedValuePath="DishId" Width="200" Height="28" Margin="0,0,15,0"/>

                    <TextBlock Text="Số lượng:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtQuantity" Width="80" Height="28" Margin="0,0,15,0"/>

                    <Button Content="Thêm vào phiếu" Width="100" Height="28" Background="#007bff" Foreground="White" Click="BtnAddDish_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgDetails" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#f1f3f5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Món" Binding="{Binding DishId}" Width="80"/>
                        <DataGridTextColumn Header="Tên Món" Binding="{Binding DishName}" Width="*"/>
                        <DataGridTextColumn Header="Số Lượng Xuất" Binding="{Binding Quantity}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock x:Name="txtError" Foreground="Red" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Button Content="Hủy" Width="80" Height="30" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Lưu Phiếu Xuất" Width="120" Height="30" Background="#fd7e14" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>